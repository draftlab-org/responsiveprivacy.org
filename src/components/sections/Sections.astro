---
import ButtonSection from '@components/sections/ButtonSection.astro';
import CardSection from '@components/sections/CardSection.astro';
import ContactFormSection from '@components/sections/ContactFormSection.astro';
import FeatureSection from '@components/sections/FeatureSection.astro';
import FlexiSection from '@components/sections/FlexiSection.astro';
import RichTextSection from '@components/sections/RichTextSection.astro';
import SectionLayout from '@layouts/SectionLayout.astro';

const { sectionItems } = Astro.props;
---

{
  sectionItems?.map((section: any) => {
    const sectionLabel = `section > ${section.type}`;

    const content = (() => {
      switch (section.type) {
        case 'button':
          return (
            <ButtonSection
              title={section.title}
              buttons={section.buttons}
            />
          );
        case 'flexi':
          return (
            <FlexiSection
              title={section.title}
              description={section.description}
              sections={section.sections}
            />
          );
        case 'feature':
          return (
            <FeatureSection
              title={section.title}
              titleSize={section.titleSize}
              body={section.body}
              bodySize={section.bodySize}
              layout={section.layout}
              illustration={section.illustration}
              illustrationPosition={section.illustrationPosition}
              items={section.items}
              bottomLine={section.bottomLine}
              buttons={section.buttons}
            />
          );
        case 'richText':
          return (
            <RichTextSection
              content={section.content}
              withTOC={section.withTOC}
              buttons={section.buttons}
            />
          );
        case 'card':
          return (
            <CardSection
              title={section.title}
              description={section.description}
              cards={section.cards}
              buttons={section.buttons}
            />
          );
        case 'contactForm':
          return <ContactFormSection />;
        default:
          return null;
      }
    })();

    return (
      <SectionLayout
        bgColor={section.background?.bgColor}
        bgType={section.background?.bgType}
        bgImage={section.backgroundImage}
        sectionLabel={sectionLabel}
      >
        {content}
      </SectionLayout>
    );
  })
}
