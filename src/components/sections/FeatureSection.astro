---
import { Image } from 'astro:assets';
import Heading from '@components/atoms/Heading.astro';
import { renderMarkdown } from '@utils/renderMarkdown';
import type { ImageMetadata } from 'astro';
import IconCheck from '~icons/mdi/check-outline';

export interface Item {
  title: string;
  description?: string;
}

export interface Props {
  title: string;
  titleSize?: 1 | 2 | 3 | 4 | 5 | 6;
  body?: string;
  bodySize?: 'normal' | 'large';
  illustration?: ImageMetadata;
  illustrationPosition?: 'top' | 'bottom' | 'left' | 'right';
  items?: Item[];
}

const {
  title,
  titleSize = 2,
  body,
  bodySize = 'normal',
  illustration,
  illustrationPosition = 'top',
  items,
} = Astro.props;

const bodyHtml = body ? (await renderMarkdown(body)).html : null;
const proseClass = bodySize === 'large' ? 'text-5xl' : 'prose';

const hasItems = !!items && items.length > 0;
const hasIllustration = !!illustration;

// Layout mode: items > illustration position > centered
const mode = hasItems
  ? 'split-items'
  : hasIllustration
    ? `split-${illustrationPosition}`
    : 'centered';

const sectionContainerStyle = "mx-auto max-w-4xl text-center"
---

{
	mode === 'centered' && (
		<div class={sectionContainerStyle}>
			<Heading level={titleSize} class="mb-6">
				{title}
			</Heading>
			{bodyHtml && (
				<div class={`mx-auto ${proseClass} max-w-2xl`}>
					<Fragment set:html={bodyHtml} />
				</div>
			)}
		</div>
	)
}

{
	mode === 'split-top' && illustration && (
		<div class="mx-auto max-w-3xl text-center">
			<div class="mx-auto mb-8 flex max-w-[22.4rem] justify-center">
				<Image src={illustration} alt="" class="h-auto w-full" />
			</div>
			<Heading level={titleSize} class="mb-6">
				{title}
			</Heading>
			{bodyHtml && (
				<div class={`mx-auto ${proseClass} max-w-2xl`}>
					<Fragment set:html={bodyHtml} />
				</div>
			)}
		</div>
	)
}

{
	mode === 'split-bottom' && illustration && (
		<div class="mx-auto max-w-3xl text-center">
			<Heading level={titleSize} class="mb-6">
				{title}
			</Heading>
			{bodyHtml && (
				<div class={`mx-auto ${proseClass} max-w-2xl`}>
					<Fragment set:html={bodyHtml} />
				</div>
			)}
			<div class="mx-auto mt-8 flex max-w-[22.4rem] justify-center">
				<Image src={illustration} alt="" class="h-auto w-full" />
			</div>
		</div>
	)
}

{
	(mode === 'split-left' || mode === 'split-right') && illustration && (
		<div
			class={`grid items-center gap-10 md:grid-cols-2 md:gap-16 ${mode === 'split-left' ? '' : 'md:[&>*:first-child]:order-1'}`}
		>
			<div class={mode === 'split-left' ? 'md:order-1' : 'md:order-2'}>
				<Image
					src={illustration}
					alt=""
					class="h-auto w-full max-w-[22.4rem]"
				/>
			</div>
			<div class={mode === 'split-left' ? 'md:order-2' : 'md:order-1'}>
				<Heading level={titleSize} class="mb-6">
					{title}
				</Heading>
				{bodyHtml && (
					<div class={`${proseClass} max-w-none`}>
						<Fragment set:html={bodyHtml} />
					</div>
				)}
			</div>
		</div>
	)
}

{
	mode === 'split-items' && (
		<div class="grid items-start gap-10 md:grid-cols-2 md:gap-16">
			<div>
				<Heading level={titleSize} class="mb-6">
					{title}
				</Heading>
				{bodyHtml && (
					<div class={`${proseClass} max-w-none`}>
						<Fragment set:html={bodyHtml} />
					</div>
				)}
			</div>
			<ul class="grid gap-x-8 gap-y-6 sm:grid-cols-2">
				{items!.map((item) => (
					<li class="flex gap-3">
						<IconCheck className="mt-0.5 size-6 shrink-0 text-green-600" />
						<div>
							<p class="font-display font-semibold text-gray-900">
								{item.title}
							</p>
							{item.description && (
								<p class="mt-1 text-sm text-gray-700">{item.description}</p>
							)}
						</div>
					</li>
				))}
			</ul>
		</div>
	)
}
