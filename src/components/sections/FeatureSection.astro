---
import { Image } from 'astro:assets';
import Heading from '@components/atoms/Heading.astro';
import ButtonGroup, {
  type ButtonType,
} from '@components/molecules/ButtonGroup.astro';
import FeatureItems, {
  type Item,
} from '@components/molecules/FeatureItems.astro';
import { renderMarkdown } from '@utils/renderMarkdown';
import type { ImageMetadata } from 'astro';

export type { Item };

export interface Props {
  title: string;
  titleSize?: 1 | 2 | 3 | 4 | 5 | 6;
  body?: string;
  bodySize?: 'normal' | 'large';
  layout?: 'stacked' | 'split';
  illustration?: ImageMetadata;
  illustrationPosition?: 'top' | 'bottom';
  items?: Item[];
  bottomLine?: string;
  buttons?: ButtonType[];
}

const {
  title,
  titleSize = 2,
  body,
  bodySize = 'normal',
  layout = 'stacked',
  illustration,
  illustrationPosition = 'top',
  items,
  bottomLine,
  buttons,
} = Astro.props;

const bodyHtml = body ? (await renderMarkdown(body)).html : null;
const bottomLineHtml = bottomLine
  ? (await renderMarkdown(bottomLine)).html
  : null;
const proseClass = bodySize === 'large' ? 'prose prose-p:text-xl' : 'prose prose-p:text-xl';

const hasItems = !!items && items.length > 0;
const hasButtons = !!buttons && buttons.length > 0;
const hasIllustration = !!illustration;
const showIllustrationTop = hasIllustration && illustrationPosition === 'top';
const showIllustrationBottom =
  hasIllustration && illustrationPosition === 'bottom';
---

<div class="flex flex-col gap-10">
	{
		showIllustrationTop && illustration && (
			<div class="mx-auto flex max-w-[22.4rem] justify-center">
				<Image src={illustration} alt="" class="block h-64 w-full" />
			</div>
		)
	}

	{
		layout === 'stacked' ? (
			<div class="mx-auto max-w-4xl text-center">
				<Heading level={titleSize} class={bodyHtml ? 'mb-6' : ''}>
					{title}
				</Heading>
				{bodyHtml && (
					<div class={`mx-auto ${proseClass} max-w-4xl`}>
						<Fragment set:html={bodyHtml} />
					</div>
				)}
			</div>
		) : (
			<div class="mx-auto grid w-full gap-6 md:w-3/4 md:grid-cols-2 md:gap-12">
				<div class="w-full">
					<Heading level={titleSize} class="md:text-right">
						{title}
					</Heading>
				</div>
				{bodyHtml && (
					<div class={`${proseClass} max-w-none md:text-left`}>
						<Fragment set:html={bodyHtml} />
					</div>
				)}
			</div>
		)
	}

	{hasItems && <FeatureItems items={items!} />}

	{
		bottomLineHtml && (
			<div class="mx-auto prose max-w-4xl text-center prose-p:text-xl md:prose-p:text-2xl">
				<Fragment set:html={bottomLineHtml} />
			</div>
		)
	}

	{hasButtons && <ButtonGroup buttons={buttons!} />}

	{
		showIllustrationBottom && illustration && (
			<div class="mx-auto flex max-w-[22.4rem] justify-center">
				<Image src={illustration} alt="" class="h-64 w-full" />
			</div>
		)
	}
</div>
