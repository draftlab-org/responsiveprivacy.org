---
import ButtonGroup, {
  type ButtonType,
} from '@components/molecules/ButtonGroup.astro';
import TOC from '@components/organisms/TOC';
import renderMarkdownWithImages from '@utils/renderMarkdown';

export interface Props {
  content: string;
  withTOC?: boolean;
  id?: string;
  buttons?: ButtonType[];
}

const { content, withTOC = false, id, buttons } = Astro.props;

const sectionId = id || `richtext-${Math.random().toString(36)}`;

const { html, toc } = await renderMarkdownWithImages(
  content,
  withTOC,
  withTOC ? sectionId : undefined
);

const hasTOC = withTOC && toc && toc.length > 0;
const hasButtons = !!buttons && buttons.length > 0;
---

<div class="flex flex-col gap-10">
  {
    hasTOC ? (
      <div class="mx-auto max-w-6xl">
        <div class="grid grid-cols-1 gap-8 lg:grid-cols-[1fr_250px]">
          <div class="prose max-w-3xl">
            <Fragment set:html={html} />
          </div>
          <aside class="hidden lg:block">
            <TOC client:load entries={toc!} />
          </aside>
        </div>
      </div>
    ) : (
      <div class="prose mx-auto max-w-3xl">
        <Fragment set:html={html} />
      </div>
    )
  }

  {hasButtons && <ButtonGroup buttons={buttons!} />}
</div>
