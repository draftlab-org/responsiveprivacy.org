---
import Button from '@components/atoms/Button.astro';
import IconGithub from '~icons/simple-icons/github';
import IconNpm from '~icons/simple-icons/npm';

export type ButtonIcon = 'github' | 'npm';

export interface ButtonType {
  variant: string;
  size: string;
  href: string;
  text: string;
  icon?: ButtonIcon;
}

export interface Props {
  title?: string;
  buttons?: ButtonType[];
  class?: string;
}

const {
  title,
  buttons = [],
  class: className = '',
} = Astro.props;

const iconMap = {
  github: IconGithub,
  npm: IconNpm,
} as const;
---

<div class:list={["mx-auto max-w-7xl px-4 sm:px-6 lg:px-8", className]}>
	<!-- Section Header -->
	{
		title && (
			<div class="mb-12 text-center">
				<h2 class="mb-4">{title}</h2>
			</div>
		)
	}

	<!-- Buttons -->
	{
		buttons.length > 0 && (
			<div class="flex flex-wrap justify-center gap-4">
				{buttons.map((button) => {
					const Icon = button.icon ? iconMap[button.icon] : null;
					return (
						<Button
							type="button"
							as="a"
							variant={button.variant as any}
							size={button.size as any}
							href={button.href}
							class="inline-flex items-center gap-2"
						>
							{Icon && <Icon class="size-5 shrink-0" aria-hidden="true" />}
							<span>{button.text}</span>
						</Button>
					);
				})}
			</div>
		)
	}
</div>
